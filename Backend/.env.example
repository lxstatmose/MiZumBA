APP_ENV=local
DEBUG=true
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/mizumba
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change-me-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
EMAIL_CONFIRMATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
MAX_AUDIO_UPLOAD_SIZE_MB=25
ENABLE_WHISPER_TRANSCRIPTION=false
STORAGE_PROVIDER=local
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@mizumba.app
SMTP_USE_TLS=true
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
